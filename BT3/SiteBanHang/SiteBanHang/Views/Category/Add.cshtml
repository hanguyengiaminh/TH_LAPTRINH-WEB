@model SiteBanHang.Models.Category

@{
    ViewData["Title"] = "Them danh muc";
}

<h1 class="h2 mb-4">Them danh muc moi</h1>

<form asp-action="Add" method="post" class="card shadow-sm p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-4">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Luu danh muc</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lai</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
