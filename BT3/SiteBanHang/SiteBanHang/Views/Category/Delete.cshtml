@model SiteBanHang.Models.Category

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="card shadow-sm p-4">
    <h1 class="h2 text-danger">Xác nhận xóa danh mục</h1>
    <p class="mb-2">Bạn có chắc chắn muốn xóa danh mục <strong>@Model.Name</strong> không?</p>
    <p class="text-muted">Lưu ý: danh mục còn sản phẩm sẽ không xóa được do ràng buộc dữ liệu.</p>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </form>
</div>
