@model SiteBanHang.Models.Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<h1 class="h2 mb-4">Thêm sản phẩm mới</h1>

<form asp-action="Add" method="post" enctype="multipart/form-data" class="card shadow-sm p-4" id="productAddForm">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" type="text" class="form-control price-input" inputmode="numeric" placeholder="Ví dụ: 150.000 hoặc 150000" />
        <div class="form-text">Mệnh giá Vnd, ví dụ: 150.000 hoặc 150,000.</div>
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
            <option value="">-- Chọn danh mục --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-lg-6">
            <label class="form-label" for="imageInput">Hình ảnh sản phẩm</label>
            <input id="imageInput" name="imageFile" type="file" class="form-control" accept="image/*" />
            <div class="form-text">Khi bạn chọn ảnh, hệ thống sẽ hiển thị xem trước ngay bên phải.</div>
        </div>
        <div class="col-lg-6">
            <img
                id="previewImage"
                src="https://placehold.co/600x420?text=San+pham"
                alt="Xem trước ảnh sản phẩm"
                class="img-thumbnail product-thumb-preview" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Lưu sản phẩm</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const imageInput = document.getElementById("imageInput");
        const previewImage = document.getElementById("previewImage");
        const addForm = document.getElementById("productAddForm");
        const addPriceInput = addForm?.querySelector(".price-input");

        imageInput?.addEventListener("change", function (event) {
            const file = event.target.files[0];
            if (!file) {
                previewImage.src = "https://placehold.co/600x420?text=San+pham";
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                previewImage.src = e.target.result;
            };
            reader.readAsDataURL(file);
        });

        addForm?.addEventListener("submit", function () {
            if (!addPriceInput) {
                return;
            }

            addPriceInput.value = addPriceInput.value.replace(/[.,\s]/g, "");
        });
    </script>
}
