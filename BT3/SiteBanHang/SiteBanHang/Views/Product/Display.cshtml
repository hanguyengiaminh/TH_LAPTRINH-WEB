@model SiteBanHang.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<section class="detail-layout">
    <div class="detail-image-card">
        <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://placehold.co/600x420?text=San+pham" : Model.ImageUrl)" class="product-detail-image" alt="@Model.Name" />
    </div>
    <div class="detail-copy-card">
        <p class="eyebrow">Thông tin sản phẩm</p>
        <h1>@Model.Name</h1>
        <p class="detail-price">@Model.Price.ToString("N0") VNĐ</p>
        <p><strong>Danh mục:</strong> @(Model.Category?.Name ?? "Chưa có")</p>
        <p class="detail-description">@Model.Description</p>
        <div class="d-flex flex-wrap gap-2 mt-4">
            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-hero-primary">Sửa sản phẩm</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Xóa</a>
            <a asp-action="Index" class="btn btn-hero-secondary">Quay lại</a>
        </div>
    </div>
</section>
