@model SiteBanHang.Models.Product

@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<h1 class="h2 mb-4">Cập nhật sản phẩm</h1>

<form asp-action="Update" method="post" enctype="multipart/form-data" class="card shadow-sm p-4" id="productUpdateForm">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" type="text" class="form-control price-input" inputmode="numeric" placeholder="Ví dụ: 150.000 hoặc 150000" />
        <div class="form-text">Bạn có thể nhập giá theo kiểu Việt Nam, ví dụ: 150.000 hoặc 150,000.</div>
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-lg-6">
            <label class="form-label" for="imageInput">Hình ảnh sản phẩm</label>
            <input id="imageInput" name="imageFile" type="file" class="form-control" accept="image/*" />
            <div class="form-text">Nếu không chọn ảnh mới, hệ thống sẽ giữ ảnh hiện tại.</div>
        </div>
        <div class="col-lg-6">
            <img
                id="previewImage"
                src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://placehold.co/600x420?text=San+pham" : Model.ImageUrl)"
                alt="@Model.Name"
                class="img-thumbnail product-thumb-preview" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const imageInput = document.getElementById("imageInput");
        const previewImage = document.getElementById("previewImage");
        const updateForm = document.getElementById("productUpdateForm");
        const updatePriceInput = updateForm?.querySelector(".price-input");

        imageInput?.addEventListener("change", function (event) {
            const file = event.target.files[0];
            if (!file) {
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                previewImage.src = e.target.result;
            };
            reader.readAsDataURL(file);
        });

        updateForm?.addEventListener("submit", function () {
            if (!updatePriceInput) {
                return;
            }

            updatePriceInput.value = updatePriceInput.value.replace(/[.,\s]/g, "");
        });
    </script>
}
