@model IEnumerable<SiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
}

<section class="content-panel mb-4">
    <div class="section-header">
        <div>
            <p class="eyebrow">Danh sách hiện có</p>
            <h1>Quản lý sản phẩm</h1>
            <p class="section-copy">Các sản phẩm được trình bày trong bảng rõ ràng, ưu tiên khả năng đọc và thao tác nhanh.</p>
        </div>
        <a asp-action="Add" class="btn btn-hero-primary">Thêm sản phẩm</a>
    </div>
</section>

<div class="table-card">
    <div class="table-responsive">
        <table class="table product-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá</th>
                    <th>Danh mục</th>
                    <th>Mô tả</th>
                    <th class="text-end">Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    var imageUrl = string.IsNullOrWhiteSpace(product.ImageUrl)
                        ? "https://placehold.co/120x160?text=No+Image"
                        : product.ImageUrl;

                    <tr>
                        <td>
                            <img src="@imageUrl" alt="@product.Name" class="product-list-thumb" />
                        </td>
                        <td class="fw-semibold">@product.Name</td>
                        <td>@product.Price.ToString("N0") VNĐ</td>
                        <td>@(product.Category?.Name ?? "Chưa có")</td>
                        <td>@product.Description</td>
                        <td class="text-end">
                            <div class="action-group">
                                <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary">Xem</a>
                                <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
