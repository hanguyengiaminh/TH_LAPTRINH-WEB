@{
    ViewData["Title"] = "Trang chủ";
}

<section class="hero-panel mb-5">
    <div class="row g-4 align-items-center">
        <div class="col-lg-7">
            <p class="eyebrow">Website bán hàng với ASP.NET Core MVC</p>
            <h1 class="hero-title">Đây là Website Bán Hàng của Hà Nguyễn Gia Minh</h1>
            <p class="hero-copy">
                Website Bán sách nhiều thể loại sách khác nhau với giá ưu đãi và có nhiều các loại sách hấp dẫn khác nhau.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a asp-controller="Product" asp-action="Index" class="btn btn-hero-primary">Xem sản phẩm</a>
                <a asp-controller="Category" asp-action="Index" class="btn btn-hero-secondary">Xem danh mục</a>
            </div>
        </div>
        <div class="col-lg-5">
            <aside class="note-card">
                <h2 class="note-title">Điểm nhấn giao diện</h2>
                <ul class="note-list">
                    <li>Bố cục trung tâm, khoảng trắng thoáng và nhịp đọc rõ ràng</li>
                    <li>Tiêu đề serif lớn kết hợp chữ nội dung sans-serif dễ theo dõi</li>
                    <li>Nút kêu gọi hành động nổi bật nhưng không quá chói</li>
                    <li>Các khối thông tin được chia box, viền và bóng nhẹ để dễ quan sát</li>
                </ul>
            </aside>
        </div>
    </div>
</section>

<section class="row g-4">
    <div class="col-md-4">
        <article class="feature-box h-100">
            <p class="eyebrow">Sản phẩm</p>
            <h2>Quản lý kho hàng</h2>
            <p>Theo dõi danh sách sản phẩm, hình ảnh, mô tả, giá bán và thao tác chỉnh sửa ngay trên hệ thống.</p>
            <a asp-controller="Product" asp-action="Index" class="feature-link">Đi đến sản phẩm</a>
        </article>
    </div>
    <div class="col-md-4">
        <article class="feature-box h-100">
            <p class="eyebrow">Danh mục</p>
            <h2>Sắp xếp nội dung</h2>
            <p>Phân nhóm sản phẩm để người dùng quan sát dễ hơn và quản trị dữ liệu gọn gàng hơn.</p>
            <a asp-controller="Category" asp-action="Index" class="feature-link">Đi đến danh mục</a>
        </article>
    </div>
    <div class="col-md-4">
        <article class="feature-box h-100 accent-box">
            <p class="eyebrow">Giới thiệu</p>
            <h2>Không gian trực quan</h2>
            <p>Giao diện được nhấn mạnh bằng màu mực, nền giấy và các khối nội dung có cấu trúc chặt chẽ.</p>
            <a asp-controller="Home" asp-action="Privacy" class="feature-link">Xem thêm</a>
        </article>
    </div>
</section>
